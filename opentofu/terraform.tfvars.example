# Proxmox access
proxmox_endpoint     = "https://pve.example.local:8006/"
proxmox_api_token    = "terraform@pve!asterisk=REPLACE_WITH_TOKEN_SECRET"
proxmox_insecure_tls = true
proxmox_node         = "pve"

# Existing cloud-init template to clone
# Example: VM 9024 is a Debian/Ubuntu cloud-init template with qemu-guest-agent installed.
template_vm_id = 9024

# PBX VM
vm_id            = 150
vm_name          = "pbx1"
vm_cpu_cores     = 2
vm_memory_mb     = 2048
vm_disk_size_gb  = 32

# Storage and network
vm_disk_datastore_id   = "local-lvm"
cloud_init_datastore_id = "local-lvm"
vm_bridge              = "vmbr0"
vm_vlan_id             = null

# Static IP recommended for a PBX.
# Use "dhcp" only if you also set ansible_host_override or update inventory after boot.
vm_ipv4_address = "192.168.1.50/24"
vm_ipv4_gateway = "192.168.1.1"
dns_domain      = "local"
dns_servers     = ["192.168.1.1", "1.1.1.1"]

# Cloud-init admin user for Ansible
vm_username = "ansible"
ssh_public_keys = [
  "ssh-ed25519 AAAA_REPLACE_WITH_YOUR_PUBLIC_KEY yourname@workstation"
]

# Optional. Prefer SSH keys instead of passwords.
vm_user_password = null

# For DHCP only: set this after you know the lease.
ansible_host_override = ""
